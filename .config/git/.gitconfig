# =========================
# Git LFS
# =========================
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true


# =========================
# User Identity
# =========================
[user]
    name = Agni Datta
    email = dattadunga@gmail.com
    signingkey = 83AF83DA47DE7F22


# =========================
# Signing
# =========================
[commit]
    gpgsign = true

[tag]
    gpgSign = true

[gpg]
    format = openpgp


# =========================
# Core
# =========================
[core]
    editor = nvim
    pager = delta
    autocrlf = input
    preloadindex = true
    untrackedCache = true
    fsmonitor = true
    excludesfile = ~/.config/git/ignore


# =========================
# Defaults
# =========================
[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true
    followTags = true

[fetch]
    prune = true
    pruneTags = true
    parallel = 25

[rebase]
    autoStash = true
    updateRefs = true

[merge]
    tool = nvimdiff
    conflictstyle = zdiff3

[diff]
    tool = nvimdiff
    colorMoved = default
    algorithm = histogram


# =========================
# Performance / Maintenance
# =========================
[rerere]
    enabled = true

[maintenance]
    auto = true

[gc]
    writeCommitGraph = true


# =========================
# UI / Colors
# =========================
[color]
    ui = auto

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Nord
    features = decorations

[delta "decorations"]
    commit-decoration-style = blue ol
    file-style = yellow ul
    hunk-header-style = file line-number syntax


# =========================
# Quality of Life
# =========================
[help]
    autocorrect = prompt

[status]
    submoduleSummary = true


# =========================
# Aliases
# =========================
[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    s = status -sb

    last = log -1 HEAD

    lg = log --graph \
        --pretty=format:'%C(yellow)%h%C(reset) - %C(cyan)%ad%C(reset) %s %C(green)(%cr)%C(reset) %C(bold blue)<%an>%C(reset)%d' \
        --date=short

    lgg = log --oneline --decorate --graph --all

    amend = commit --amend
    unstage = restore --staged
    fixup = commit --fixup
    squash = rebase -i --autosquash

    d = diff
    dc = diff --cached

    undo = reset --soft HEAD~1

    cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"


# =========================
# Includes
# =========================
[include]
    path = ~/.gitconfig.local


# =========================
# URL Rewrites
# =========================
[url "git@git.overleaf.com:"]
    insteadOf = https://git.overleaf.com/


# =========================
# Credentials
# =========================

# Global secure credential storage
# Recommended for Linux:
# sudo pacman -S libsecret
# git config --global credential.helper /usr/lib/git-core/git-credential-libsecret

[credential]
    helper = /usr/lib/git-core/git-credential-libsecret


# Overleaf
[credential "https://git.overleaf.com"]
    helper = /usr/lib/git-core/git-credential-libsecret
    provider = generic


# GitHub
[credential "https://github.com"]
    helper = !/usr/bin/gh auth git-credential


# GitHub Gists
[credential "https://gist.github.com"]
    helper = !/usr/bin/gh auth git-credential
